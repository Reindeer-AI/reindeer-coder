{
  "name": "reindeer-coder",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "app",
    "vscode-extension"
  ],
  "scripts": {
    "dev": "bun run --filter app dev",
    "dev:ext": "bun run --filter vscode-extension watch",
    "build": "bun run --filter app build",
    "build:ext": "bun run --filter vscode-extension build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "check": "bun run --filter app check"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "bun-types": "^1.3.3"
  }
}
