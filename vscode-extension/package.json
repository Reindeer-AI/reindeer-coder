{
	"name": "reindeer-coder",
	"displayName": "Reindeer Coder",
	"description": "Connect to your Reindeer Coder remote workspaces",
	"version": "0.1.0",
	"publisher": "reindeer-ai",
	"repository": {
		"type": "git",
		"url": "https://gitlab.com/reindeerai/reindeer-coder.git"
	},
	"engines": {
		"vscode": "^1.85.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
		"onView:reindeerCoderTasks"
	],
	"main": "./dist/extension.js",
	"contributes": {
		"viewsContainers": {
			"activitybar": [
				{
					"id": "reindeer-coder",
					"title": "Reindeer Coder",
					"icon": "resources/icon.svg"
				}
			]
		},
		"views": {
			"reindeer-coder": [
				{
					"id": "reindeerCoderTasks",
					"name": "Tasks"
				}
			]
		},
		"commands": [
			{
				"command": "reindeerCoder.login",
				"title": "Reindeer Coder: Login"
			},
			{
				"command": "reindeerCoder.logout",
				"title": "Reindeer Coder: Logout"
			},
			{
				"command": "reindeerCoder.refreshTasks",
				"title": "Reindeer Coder: Refresh Tasks",
				"icon": "$(refresh)"
			},
			{
				"command": "reindeerCoder.createNewTask",
				"title": "Reindeer Coder: New Task",
				"icon": "$(add)"
			},
			{
				"command": "reindeerCoder.connectTask",
				"title": "Open Workspace (Remote-SSH)",
				"icon": "$(folder-opened)"
			},
			{
				"command": "reindeerCoder.connectTerminalOnly",
				"title": "Open Terminal",
				"icon": "$(terminal)"
			},
			{
				"command": "reindeerCoder.testFromLocalBrowser",
				"title": "Test from Local Browser",
				"icon": "$(browser)"
			},
			{
				"command": "reindeerCoder.disconnectTask",
				"title": "Disconnect from Task"
			},
			{
				"command": "reindeerCoder.showDebugInfo",
				"title": "Reindeer Coder: Show Debug Info"
			},
			{
				"command": "reindeerCoder.switchTmuxSession",
				"title": "Switch Tmux Session"
			}
		],
		"menus": {
			"terminal/context": [
				{
					"command": "reindeerCoder.switchTmuxSession",
					"group": "navigation"
				}
			],
			"view/title": [
				{
					"command": "reindeerCoder.createNewTask",
					"when": "view == reindeerCoderTasks",
					"group": "navigation"
				},
				{
					"command": "reindeerCoder.refreshTasks",
					"when": "view == reindeerCoderTasks",
					"group": "navigation"
				}
			],
			"view/item/context": [
				{
					"command": "reindeerCoder.connectTask",
					"when": "view == reindeerCoderTasks && viewItem == task",
					"group": "inline@1"
				},
				{
					"command": "reindeerCoder.connectTerminalOnly",
					"when": "view == reindeerCoderTasks && viewItem == task",
					"group": "inline@2"
				},
				{
					"command": "reindeerCoder.testFromLocalBrowser",
					"when": "view == reindeerCoderTasks && viewItem == task",
					"group": "inline@3"
				}
			]
		},
		"configuration": {
			"title": "Reindeer Coder",
			"properties": {
				"reindeerCoder.apiUrl": {
					"type": "string",
					"default": "https://vibe.reindeerlabs.ai",
					"description": "Reindeer Coder API URL"
				},
				"reindeerCoder.auth0Domain": {
					"type": "string",
					"default": "dev-0d0uyl2iqc17144b.us.auth0.com",
					"description": "Auth0 domain"
				},
				"reindeerCoder.auth0ClientId": {
					"type": "string",
					"default": "i6QxH7zvtkkm5pD1iCS4mcIavVXhuOiZ",
					"description": "Auth0 client ID (same as web app)"
				},
				"reindeerCoder.auth0Audience": {
					"type": "string",
					"default": "https://vibe.reindeerlabs.ai",
					"description": "Auth0 API audience (should match web app)"
				},
				"reindeerCoder.auth0OrganizationId": {
					"type": "string",
					"default": "org_9WU9bq88J0jAPjmM",
					"description": "Auth0 organization ID (optional, leave empty if not using organizations)"
				},
				"reindeerCoder.gcpProject": {
					"type": "string",
					"default": "reindeer-vibe",
					"description": "GCP project ID for compute instances"
				},
				"reindeerCoder.mountPath": {
					"type": "string",
					"default": "~/reindeer-coder-mounts",
					"description": "[Deprecated] This setting is no longer used as the extension now uses VSCode Remote-SSH instead of SSHFS"
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run build",
		"build": "node build.js",
		"watch": "node build.js --watch",
		"package": "vsce package"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.11",
		"@types/node": "^20.10.0",
		"@types/vscode": "^1.85.0",
		"@vscode/vsce": "^3.7.1",
		"esbuild": "^0.19.0",
		"typescript": "^5.3.0"
	},
	"dependencies": {
		"axios": "^1.6.0"
	}
}
