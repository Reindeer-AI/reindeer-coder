# Application Configuration
APP_URL=https://your-app-domain.com

# Auth0 Configuration (Server)
AUTH0_DOMAIN=your-tenant.auth0.com

# Auth0 Configuration (Client - VITE_ prefix makes them available in browser)
VITE_AUTH0_DOMAIN=your-tenant.auth0.com
VITE_AUTH0_CLIENT_ID=your-client-id
VITE_AUTH0_ORG_ID=your-org-id
VITE_AUTH0_AUDIENCE=https://your-app-domain.com

# GCP Configuration
GCP_PROJECT_ID=your-gcp-project
GCP_ZONE=us-central1-a
GCP_NETWORK=default
GCP_SUBNET=
# Service account for the VMs (has access to Vertex AI, etc.)
GCP_VM_SERVICE_ACCOUNT=your-vm-service-account@your-project.iam.gserviceaccount.com

# Client-side GCP config (for displaying SSH commands)
VITE_GCP_PROJECT_ID=your-gcp-project

# VM Configuration
VM_IMAGE_FAMILY=ubuntu-2204-lts
VM_IMAGE_PROJECT=ubuntu-os-cloud
VM_MACHINE_TYPE=e2-standard-4
VM_USER=vibe
VITE_VM_USER=vibe

# API Keys for agents (injected into VMs via metadata)
# These are pre-loaded via Cloud Run secrets

# Anthropic API Key (required for Claude Code)
ANTHROPIC_API_KEY=sk-ant-xxx

# OpenAI API Key (required for Codex)
OPENAI_API_KEY=sk-xxx

# Google API Key for Gemini CLI (optional - if not set, Gemini uses VM service account)
# Get from: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-api-key

# Git Configuration
GIT_BASE_URL=https://gitlab.com
GIT_ORG=your-org
GIT_USER=oauth2

# GitLab Personal Access Token for both API access and cloning repositories
# Create at: https://gitlab.com/-/profile/personal_access_tokens
# Required scopes: api, read_api, read_repository, write_repository
# This token is used for:
# - Cloning private GitLab repositories
# - Reading MR comments and repository metadata
# - Authenticating glab CLI commands in VMs
GITLAB_TOKEN=glpat-xxx
GITLAB_API_URL=https://gitlab.com/api/v4

# Email domain for fallback email addresses
EMAIL_DOMAIN=your-domain.com

# Linear API key for fetching tickets
# Get your API key from Linear Settings > API > Personal API keys
LINEAR_API_KEY=lin_api_xxx

# Note: SSH keys are not needed - we use `gcloud compute ssh` which handles auth via IAP

# Database Configuration
# DB_TYPE can be 'sqlite' (default) or 'postgres'
DB_TYPE=sqlite

# SQLite Configuration (used when DB_TYPE=sqlite)
DB_FILENAME=vibe-coding.db

# PostgreSQL Configuration (used when DB_TYPE=postgres)
# Option 1: Use connection string
# DATABASE_URL=postgresql://user:password@host:port/database
# DB_CONNECTION_STRING=postgresql://user:password@host:port/database

# Option 2: Use individual parameters
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=vibe_coding
# DB_USER=postgres
# DB_PASSWORD=your-password

# CloudSQL PostgreSQL Configuration (for GCP CloudSQL)
# Use unix socket path for CloudSQL connection
# DATABASE_URL=/cloudsql/PROJECT:REGION:INSTANCE
# DB_NAME=vibe_coding
# DB_USER=your-db-user
# DB_PASSWORD=your-db-password
# Or use auto IAM authentication (recommended)
# DATABASE_URL=/cloudsql/PROJECT:REGION:INSTANCE
# DB_USER=ai-agent-readonly@your-project.iam
# DB_NAME=vibe_coding
